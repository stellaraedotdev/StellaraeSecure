# Runtime profile
STELLARAE_ENVIRONMENT=development
STELLARAE_LOG_LEVEL=info

# Choose a default build/run platform for local testing.
# Common values:
# - linux/arm64  (ARM devices)
# - linux/amd64  (x86_64/AMD64)
# - linux/riscv64 (RISC-V devices, if base images support your runtime)
STELLARAE_DOCKER_PLATFORM=linux/amd64

# Shared secrets/keys (replace before production)
OAUTH2_ADMIN_API_KEY=dev-admin-key-change-me
OAUTH2_STAFF_IDENTITY_HMAC_SECRET=dev-shared-hmac-secret-change-me
STAFFDB_OAUTH2_API_KEY=dev-oauth2-staffdb-key
STAFFDB_ADMIN_API_KEY=dev-admin-staffdb-key
STAFFDB_INTERNAL_API_KEY=dev-staffdb-internal-key

# oauth2 issuer
OAUTH2_ISSUER=https://secure.stellarae.org/oauth2/public

# Frontend build-time endpoints
VITE_OAUTH2_API_BASE_URL=http://localhost:4000
VITE_STAFFDB_API_BASE_URL=http://localhost:3000
VITE_AUTH_HANDOFF_START_URL=http://localhost:3000/auth/start?return_to=http://localhost:8080/auth/callback
VITE_ALLOW_BOOTSTRAP_LOGIN=false
VITE_AUTH_HANDOFF_REQUIRE_STATE=true
VITE_AUTH_HANDOFF_MAX_SKEW_SECONDS=300
VITE_PERSIST_SENSITIVE_SESSION_FIELDS=false
