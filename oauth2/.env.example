# oauth2 server configuration
OAUTH2_HOST=127.0.0.1
OAUTH2_PORT=4000
OAUTH2_ISSUER=https://secure.stellarae.org/oauth2/public

# service metadata
SERVICE_ID=oauth2-dev
ENVIRONMENT=development
LOG_LEVEL=info
OAUTH2_ADMIN_API_KEY=dev-admin-key-change-me

# token policy
OAUTH2_ACCESS_TOKEN_TTL_SECONDS=900
OAUTH2_REFRESH_TOKEN_TTL_SECONDS=2592000
OAUTH2_AUTH_CODE_TTL_SECONDS=300

# database connection for oauth2 persistence
DATABASE_URL=sqlite:oauth2.sqlite

# staffdb integration (account source of truth)
STAFFDB_BASE_URL=http://127.0.0.1:3000
STAFFDB_API_KEY=dev-staffdb-key-change-me
