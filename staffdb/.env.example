# StellaraeSecure staffdb Configuration Template

# Server configuration
STAFFDB_HOST=127.0.0.1
STAFFDB_PORT=3000

# Database URL
# For SQLite: sqlite:staffdb.sqlite or sqlite:///absolute/path/to/db.sqlite
# For PostgreSQL (Phase 2): postgresql://user:pass@localhost:5432/staffdb
DATABASE_URL=sqlite:staffdb.sqlite

# Service identification
SERVICE_ID=staffdb

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Security: Allowed inbound service API keys as comma-separated service:key pairs
# Required in production. Example: oauth2:long-random-key,admin:another-long-random-key
SERVICE_API_KEYS=staffdb:CHANGE_ME

# Services allowed to call mutating endpoints (POST/PATCH/DELETE)
PRIVILEGED_SERVICES=admin,oauth2,staffdb

# Security: Encryption key (from HSM in production, optional for development)
# ENCRYPTION_KEY=your-encryption-key-here
