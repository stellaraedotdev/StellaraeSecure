# StellaraeSecure staffdb Configuration Template

# Server configuration
STAFFDB_HOST=127.0.0.1
STAFFDB_PORT=3000

# Database URL
# For SQLite: sqlite:staffdb.sqlite or sqlite:///absolute/path/to/db.sqlite
# For PostgreSQL (Phase 2): postgresql://user:pass@localhost:5432/staffdb
DATABASE_URL=sqlite:staffdb.sqlite

# Service identification
SERVICE_ID=staffdb

# Environment: development, staging, production
ENVIRONMENT=development

# Log level: trace, debug, info, warn, error
LOG_LEVEL=info

# Security: Allowed inbound service API keys (comma-separated)
# Required in production
SERVICE_API_KEYS=dev-shared-key

# Optional caller identity header expected from clients for audit attribution
# X-Service-Id: oauth2|admin|...

# Security: Encryption key (from HSM in production, optional for development)
# ENCRYPTION_KEY=your-encryption-key-here
